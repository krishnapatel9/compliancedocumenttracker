{
    "openapi": "3.0.0",
    "info": {
        "title": "DocShield Compliance Document Tracker API",
        "version": "1.0.0",
        "description": "API Engine for managing regulatory compliance documents, expirations, dashboard stats, and alerts triggers."
    },
    "servers": [
        {
            "url": "http://localhost:5000",
            "description": "Local Development Server"
        }
    ],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "Document": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "title": {
                        "type": "string"
                    },
                    "category": {
                        "type": "string",
                        "enum": [
                            "license",
                            "certificate",
                            "insurance",
                            "contract",
                            "permit",
                            "tax_document"
                        ]
                    },
                    "issueDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "expiryDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "notifyEmail": {
                        "type": "string",
                        "format": "email"
                    },
                    "filePath": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "active",
                            "expiring_soon",
                            "expired"
                        ]
                    },
                    "daysRemaining": {
                        "type": "integer"
                    }
                }
            }
        }
    },
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "paths": {
        "/api/auth/login": {
            "post": {
                "summary": "Admin Login",
                "description": "Authenticate admin user and retrieve JWT token.",
                "security": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "admin@compliance.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "adminpassword"
                                    }
                                },
                                "required": [
                                    "email",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successfully authenticated.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "admin": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid credentials."
                    }
                }
            }
        },
        "/api/documents": {
            "get": {
                "summary": "List Documents",
                "description": "Retrieve documents with paginations, search text query and status expiry filters.",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "category",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "active",
                                "expiring_soon",
                                "expired"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A paginated list of documents.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "items": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Document"
                                            }
                                        },
                                        "totalItems": {
                                            "type": "integer"
                                        },
                                        "totalPages": {
                                            "type": "integer"
                                        },
                                        "page": {
                                            "type": "integer"
                                        },
                                        "limit": {
                                            "type": "integer"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Create Document",
                "description": "Upload a new PDF attachment and register metadata.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {
                                        "type": "string"
                                    },
                                    "category": {
                                        "type": "string"
                                    },
                                    "issueDate": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "expiryDate": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "notifyEmail": {
                                        "type": "string"
                                    },
                                    "description": {
                                        "type": "string"
                                    },
                                    "file": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "required": [
                                    "title",
                                    "category",
                                    "issueDate",
                                    "expiryDate",
                                    "notifyEmail",
                                    "file"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Document registered successfully."
                    },
                    "400": {
                        "description": "Validation error or file missing."
                    }
                }
            }
        },
        "/api/documents/{id}": {
            "get": {
                "summary": "Get Document Details",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Details successfully parsed."
                    },
                    "404": {
                        "description": "Document not found."
                    }
                }
            },
            "put": {
                "summary": "Update Document",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {
                                        "type": "string"
                                    },
                                    "category": {
                                        "type": "string"
                                    },
                                    "issueDate": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "expiryDate": {
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "notifyEmail": {
                                        "type": "string"
                                    },
                                    "description": {
                                        "type": "string"
                                    },
                                    "file": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Document successfully edited."
                    },
                    "404": {
                        "description": "Document not found."
                    }
                }
            },
            "delete": {
                "summary": "Delete Document",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Document and associated local file removed."
                    }
                }
            }
        },
        "/api/documents/{id}/file": {
            "get": {
                "summary": "Download PDF File",
                "description": "Download the PDF attachment for the specific compliance document.",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "PDF attachment download stream binary data.",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/dashboard": {
            "get": {
                "summary": "Dashboard Aggregated Metrics",
                "responses": {
                    "200": {
                        "description": "Regulatory stats containing expiring warnings and category counts.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "total": {
                                            "type": "integer"
                                        },
                                        "expired": {
                                            "type": "integer"
                                        },
                                        "expiring7d": {
                                            "type": "integer"
                                        },
                                        "expiring30d": {
                                            "type": "integer"
                                        },
                                        "categories": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/services/cron/trigger": {
            "post": {
                "summary": "Manual Scan Reminders",
                "description": "Administratively trigger nodal warning check and send mail notifications.",
                "responses": {
                    "200": {
                        "description": "Manual scan verification results payload."
                    }
                }
            }
        }
    }
}